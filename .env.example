# Runtime
APP_ENV=development
FLASK_ENV=development
PORT=8080
LOG_LEVEL=INFO

# Security
SECRET_KEY=replace-with-strong-random-32-plus-char-secret
SESSION_COOKIE_SECURE=0
REMEMBER_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME_MINUTES=120

# Database
# Development: sqlite fallback DevelopmentConfig içinde var.
# Production: mutlaka PostgreSQL / Cloud SQL bağlantısı verin.
DATABASE_URL=
ALLOW_SQLITE_IN_PRODUCTION=0
AUTO_CREATE_TABLES=0
MAX_EXPORT_ROWS=10000

# Rate limiting
REDIS_URL=
RATELIMIT_DEFAULT=120 per hour
LOGIN_RATE_LIMIT=5 per minute
RESET_RATE_LIMIT=3 per minute
CRITICAL_POST_RATE_LIMIT=20 per minute

# Auth lockout
AUTH_LOCKOUT_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Mail / Secret Manager
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=
MAIL_FROM_EMAIL=
MAIL_REPLY_TO=
SMTP_PASSWORD=
MAIL_SECRET_PROJECT_ID=
MAIL_PASSWORD_SECRET_NAME=
MAIL_PASSWORD_SECRET_VERSION=latest

# Scheduler
# Cloud Run web service için kapalı önerilir.
ENABLE_SCHEDULER=0
ALLOW_CLOUD_RUN_WEB_SCHEDULER=0

# Optional feature flags
HOMEPAGE_EDITOR_CAN_PUBLISH=1
DEMO_TOOLS_ENABLED=0

# Storage
STORAGE_BACKEND=local
LOCAL_UPLOAD_ROOT=
LOCAL_UPLOAD_URL_PREFIX=/static/uploads
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
GCS_UPLOAD_PREFIX=uploads
GCS_PUBLIC_BASE_URL=
GCS_CACHE_CONTROL=public, max-age=3600
GCS_MAKE_UPLOADS_PUBLIC=0

# Seed / recovery scripts
BOOTSTRAP_OWNER_EMAIL=
BOOTSTRAP_OWNER_PASSWORD=
SEED_SAMPLE_USERS=0
SEED_SAMPLE_PASSWORD=
ALLOW_ACCOUNT_RECOVERY=0
ALLOW_PROD_ACCOUNT_RECOVERY=0
RECOVERY_EMAIL=
RECOVERY_NEW_PASSWORD=
