# Runtime
APP_ENV=development
FLASK_ENV=development
PORT=8080
LOG_LEVEL=INFO

# Security
SECRET_KEY=replace-with-strong-random-32-plus-char-secret
SESSION_COOKIE_SECURE=0
REMEMBER_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME_MINUTES=120

# Database
# Development: sqlite fallback DevelopmentConfig içinde var.
# Production: mutlaka PostgreSQL / Cloud SQL bağlantısı verin.
DATABASE_URL=
ALLOW_SQLITE_IN_PRODUCTION=0
AUTO_CREATE_TABLES=0
MAX_EXPORT_ROWS=10000

# Rate limiting
# Development: boş bırakılırsa memory:// fallback kullanılır.
# Production: merkezi backend zorunludur (örn: redis://...).
RATELIMIT_STORAGE_URI=
RATELIMIT_DEFAULT=120 per hour
LOGIN_RATE_LIMIT=5 per minute
RESET_RATE_LIMIT=3 per minute
CRITICAL_POST_RATE_LIMIT=20 per minute
# Production + sqlite geçici kurtarma/smoke dışında kapalı kalmalı.
ALLOW_IN_MEMORY_RATE_LIMIT_IN_PRODUCTION=0

# Auth lockout
AUTH_LOCKOUT_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
# Proxy güveni (yalnız ters proxy arkasında etkinleştirin)
TRUST_PROXY_HEADERS=0
# Örnek: 127.0.0.1,10.0.0.5
TRUSTED_PROXY_IPS=

# Passkey / WebAuthn
# Varsayılan kapalı. Önce staging/dev ortamında kontrollü doğrulayın.
PASSKEY_ENABLED=0
# Örnek: localhost, staging.sarx.org
PASSKEY_RP_ID=
PASSKEY_RP_NAME=SAR-X ARFF
# Örnek: https://staging.sarx.org
PASSKEY_ORIGIN=
# Birden fazla origin için virgülle ayırın (örnek: https://staging.sarx.org,https://app.sarx.org)
PASSKEY_ALLOWED_ORIGINS=
PASSKEY_CHALLENGE_TTL_SECONDS=180

# Mail / Secret Manager
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=
MAIL_FROM_EMAIL=
MAIL_REPLY_TO=
SMTP_PASSWORD=
MAIL_SECRET_PROJECT_ID=
MAIL_PASSWORD_SECRET_NAME=
MAIL_PASSWORD_SECRET_VERSION=latest

# Scheduler
# Cloud Run web service için kapalı önerilir.
ENABLE_SCHEDULER=0
ALLOW_CLOUD_RUN_WEB_SCHEDULER=0

# Optional feature flags
HOMEPAGE_EDITOR_CAN_PUBLISH=1
DEMO_TOOLS_ENABLED=0

# Storage
# Production için önerilen değer: gcs
STORAGE_BACKEND=local
LOCAL_UPLOAD_ROOT=
LOCAL_UPLOAD_URL_PREFIX=/static/uploads
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
GCS_UPLOAD_PREFIX=uploads
GCS_PUBLIC_BASE_URL=
GCS_CACHE_CONTROL=public, max-age=3600
GCS_MAKE_UPLOADS_PUBLIC=0
# Production + local backend sadece geçici kurtarma/smoke için.
ALLOW_LOCAL_STORAGE_IN_PRODUCTION=0

# Google Drive OAuth
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_DRIVE_REDIRECT_URI=
GOOGLE_DRIVE_AUTH_URI=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_DRIVE_OAUTH_REQUIRE_STATE=1
GOOGLE_DRIVE_PARENT_FOLDER_ID=root
GOOGLE_DRIVE_DRILLS_ROOT_FOLDER_NAME=SAR-X Tatbikat Belgeleri

# Seed / recovery scripts
BOOTSTRAP_OWNER_EMAIL=
BOOTSTRAP_OWNER_PASSWORD=
SEED_SAMPLE_USERS=0
SEED_SAMPLE_PASSWORD=
ALLOW_ACCOUNT_RECOVERY=0
ALLOW_PROD_ACCOUNT_RECOVERY=0
RECOVERY_EMAIL=
RECOVERY_NEW_PASSWORD=
